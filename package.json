{
  "name": "@tyroneross/interface-built-right",
  "version": "1.4.0",
  "description": "End-to-end design tool for AI coding agents. Guided UI builds, iOS/macOS/web design guidance, Calm Precision principles, visual validation, interaction testing, mockup matching, cross-browser. Custom CDP engine.",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyroneross/interface-built-right.git"
  },
  "homepage": "https://github.com/tyroneross/interface-built-right#readme",
  "bugs": {
    "url": "https://github.com/tyroneross/interface-built-right/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "ibr": "dist/bin/ibr.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/native/swift/ibr-ax-extract/Package.swift",
    "src/native/swift/ibr-ax-extract/Sources",
    ".claude-plugin",
    ".codex-plugin",
    ".mcp.json",
    "adapters",
    "agents",
    "assets",
    "commands",
    "hooks",
    "mobile-ui/sim-driver/Package.swift",
    "mobile-ui/sim-driver/Sources",
    "scripts",
    "skills",
    "universal",
    "references",
    "templates"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js || true",
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:ts && npm run build:sim-driver",
    "build:ts": "tsup",
    "build:sim-driver": "node scripts/build-sim-driver.js",
    "build:cli": "tsup src/bin/ibr.ts --format cjs --outDir dist/bin",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "ibr": "node dist/bin/ibr.js",
    "ibr:dev": "tsx src/bin/ibr.ts",
    "ui": "cd web-ui && npm run dev",
    "snapshot": "node dist/bin/ibr.js start",
    "compare": "node dist/bin/ibr.js check",
    "diff": "node dist/bin/ibr.js check",
    "sessions": "node dist/bin/ibr.js list",
    "login": "node dist/bin/ibr.js login",
    "logout": "node dist/bin/ibr.js logout",
    "mcp": "node dist/mcp/server.js",
    "plugin:install-codex": "node scripts/install-codex-plugin.mjs"
  },
  "keywords": [
    "design-tool",
    "ui-design",
    "build-orchestration",
    "design-validation",
    "ui-testing",
    "css-audit",
    "cdp",
    "claude-code",
    "codex",
    "accessibility",
    "visual-regression"
  ],
  "author": "Tyrone Ross, Jr",
  "dependencies": {
    "commander": "^15.0.0",
    "nanoid": "^5.1.15",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
